generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WaitlistEntry {
  id            String    @id @default(cuid())
  email         String    @unique
  
  // Referral tracking
  referralCode  String    @unique
  referredBy    String?
  referralCount Int       @default(0)
  
  // Priority scoring
  priority      Int       @default(0)
  
  // Status
  status        String    @default("waiting") // waiting, invited, registered
  invitedAt     DateTime?
  
  // Metadata
  ipAddress     String?
  userAgent     String?
  source        String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([email])
  @@index([referralCode])
  @@index([status])
  @@index([createdAt])
}
