# ============================================
# GirlyPopChat Environment Variables
# ============================================

# Database
DATABASE_URL="file:./dev.db"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# Stytch Authentication
# Get these from https://stytch.com/dashboard
STYTCH_PROJECT_ID="project-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
STYTCH_SECRET="secret-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
STYTCH_PUBLIC_TOKEN="public-token-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN="public-token-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Age Verification (k-ID / OpenAge / AgeKey)
# Get from https://k-id.com or your age verification provider
AGE_VERIFICATION_API_KEY="your-age-verification-api-key"
AGE_VERIFICATION_WEBHOOK_SECRET="your-webhook-secret"

# Jitsi (Video/WebRTC)
# Use meet.jit.si for testing, or your self-hosted domain for production
NEXT_PUBLIC_JITSI_DOMAIN="meet.jit.si"

# Imgur (Image Uploads)
# Get client ID from https://api.imgur.com/oauth2/addclient
# Choose "Anonymous usage" for simple image uploads
IMGUR_CLIENT_ID="your-imgur-client-id"

# Socket.IO Server
SOCKET_PORT="3001"
