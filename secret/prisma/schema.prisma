// GirlyPopChat Database Schema
// Stack: Stytch (Auth) + k-ID/AgeKey (Age) + LiveKit (Video) + Socket.IO (Realtime)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER - Stytch handles auth, we store minimal data
// ============================================

model User {
  id            String   @id @default(cuid())
  stytchId      String   @unique  // Stytch user ID
  
  // Profile
  username      String   @unique
  displayName   String?
  avatar        String?
  bio           String?
  gender        String?  // male, female, couple, other
  
  // Age Verification (k-ID/AgeKey)
  ageVerified   Boolean  @default(false)
  ageVerifiedAt DateTime?
  ageKeyToken   String?  @unique  // Reusable AgeKey reference
  ageThreshold  Int?     // Verified age threshold (18, 21, etc.)
  
  // Trust & Moderation
  role          String   @default("member") // member, trusted, moderator, admin
  trustScore    Int      @default(0)        // 0-100
  strikes       Strike[]
  isBanned      Boolean  @default(false)
  bannedAt      DateTime?
  bannedReason  String?
  
  // Invite System
  inviteCodeUsed String?
  invitedById    String?
  inviter        User?    @relation("InviteTree", fields: [invitedById], references: [id])
  invitedUsers   User[]   @relation("InviteTree")
  inviteCodes    InviteCode[]
  
  // Stats
  messagesCount  Int      @default(0)
  broadcastTime  Int      @default(0) // Total minutes
  joinedAt       DateTime @default(now())
  lastOnlineAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  messages       Message[]
  ownedRooms     Room[]   @relation("RoomOwner")
  broadcasts     Broadcast[]
  shadowblocksGiven  Shadowblock[] @relation("Blocker")
  shadowblocksReceived Shadowblock[] @relation("Blocked")
  sessions       Session[]
  createdProposals   RoomProposal[] @relation("ProposalCreator")
  sponsoredProposals RoomProposalSponsor[]
  
  @@index([stytchId])
  @@index([username])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stytchSession String  @unique  // Stytch session token
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([stytchSession])
}

// ============================================
// INVITE SYSTEM
// ============================================

model InviteCode {
  id            String    @id @default(cuid())
  code          String    @unique
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  usedById      String?
  usedAt        DateTime?
  maxUses       Int       @default(1)
  useCount      Int       @default(0)
  expiresAt     DateTime?
  trustBonus    Int       @default(0)
  createdAt     DateTime  @default(now())
  
  @@index([code])
}

// ============================================
// ROOM PROPOSALS (Quorum System)
// ============================================

model RoomProposal {
  id            String    @id @default(cuid())
  name          String    @unique
  displayName   String
  description   String?
  icon          String?
  
  // Creator
  createdById   String
  createdBy     User      @relation("ProposalCreator", fields: [createdById], references: [id])
  
  // Sponsors (need 5 total to create room)
  sponsors      RoomProposalSponsor[]
  sponsorCount  Int       @default(1)  // Creator is first sponsor
  
  // Settings
  isNSFW        Boolean   @default(false)
  
  // Status
  status        String    @default("pending") // pending, approved, rejected, expired
  expiresAt     DateTime?  // 24 hours from creation
  
  // Result (when approved)
  createdRoomId String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([status])
  @@index([expiresAt])
}

model RoomProposalSponsor {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    RoomProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@unique([proposalId, userId])  // One sponsor per proposal per user
  @@index([proposalId])
  @@index([userId])
}

// ============================================
// ROOMS & CHAT
// ============================================

model Room {
  id            String    @id @default(cuid())
  name          String    @unique
  displayName   String
  description   String?
  icon          String?
  
  ownerId       String
  owner         User      @relation("RoomOwner", fields: [ownerId], references: [id])
  
  isPublic      Boolean   @default(true)
  isNSFW        Boolean   @default(false)
  password      String?
  maxUsers      Int       @default(50)
  
  allowBroadcast Boolean  @default(true)
  allowImages   Boolean   @default(true)
  
  memberCount   Int       @default(0)
  messageCount  Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  messages      Message[]
  broadcasts    Broadcast[]
  
  @@index([name])
  @@index([isPublic])
}

model Message {
  id            String    @id @default(cuid())
  content       String
  type          String    @default("text") // text, system, emote, image, gif
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId        String
  room          Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  replyToId     String?
  isEdited      Boolean   @default(false)
  editedAt      DateTime?
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  
  reactions     String?   // JSON
  imageUrl      String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// BROADCAST (LiveKit)
// ============================================

model Broadcast {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  roomId        String
  room          Room      @relation(fields: [roomId], references: [id])
  
  // LiveKit
  livekitRoom   String    @unique
  livekitSid    String?
  
  // Status
  isActive      Boolean   @default(true)
  viewerCount   Int       @default(0)
  
  // Settings
  isLocked      Boolean   @default(false) // Requires approval
  title         String?
  
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  
  @@index([userId])
  @@index([roomId])
  @@index([isActive])
}

// ============================================
// MODERATION
// ============================================

model Strike {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason        String
  severity      String    @default("warning")
  issuedById    String?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  
  @@index([userId])
}

model Shadowblock {
  id            String    @id @default(cuid())
  blockerId     String
  blocker       User      @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId     String
  blocked       User      @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  reason        String?
  profileSnapshot String?
  createdAt     DateTime  @default(now())
  
  @@unique([blockerId, blockedId])
}
